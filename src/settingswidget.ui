               <string>HTTP cache</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QComboBox" name="cacheTypeComboBox">
              <property name="toolTip">
               <string>Where to keep the HTTP cache. Memory clears on exit; None disables caching.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QLabel" name="cacheMaxLabel">
              <property name="text">
               <string>Max size</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QSpinBox" name="cacheMaxSpinBox">
              <property name="toolTip">
               <string>Maximum on-disk cache size. 0 = automatic.</string>
              </property>
              <property name="specialValueText">
               <string>Automatic</string>
              </property>
              <property name="suffix">
               <string> MB</string>
              </property>
              <property name="maximum">
               <number>4096</number>
              </property>
              <property name="singleStep">
               <number>64</number>
              </property>
             </widget>
            </item>
           </layout>
          </item>
         </layout>
